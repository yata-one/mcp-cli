import {
  "moonbitlang/async/http" @async_http,
  "yata-one/mcpx/core/http" @core_http,
  "yata-one/mcpx/core/protocol" @mcp_client,
}

import {
  "moonbitlang/async" @async,
  "moonbitlang/async/http" @async_http,
  "moonbitlang/async/socket" @socket,
  "moonbitlang/core/debug" @debug,
  "moonbitlang/core/json" @json,
} for "test"

supported_targets = "native+llvm"

options(
  targets: {
    "mcp_http.mbt": [ "native", "llvm" ],
    "mcp_http_test.mbt": [ "native", "llvm" ],
  },
)
